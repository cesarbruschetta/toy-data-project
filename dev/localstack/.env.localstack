# Variáveis de ambiente para rodar as Lambdas localmente apontando para o LocalStack.
# Copie para a raiz do projeto ou exporte no terminal antes de rodar os scripts.
#
# Uso:
#   export $(cat dev/localstack/.env.localstack | xargs)

AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# Andy Lambda
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:toy-data-project-temperature

# Hamm Lambda
DATA_LAKE_BUCKET=toy-data-project-data-lake
RAW_PREFIX=raw
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/toy-data-project-temperature-queue
SQS_BATCH_SIZE=10
